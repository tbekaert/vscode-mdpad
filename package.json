{
  "name": "mdpad",
  "displayName": "mdpad",
  "description": "A lightweight markdown notepad inside VS Code",
  "version": "0.0.1",
  "publisher": "tbekaert",
  "license": "GPL-3.0-or-later",
  "icon": "images/icon.png",
  "repository": {
    "url": "https://github.com/tbekaert/vscode-mdpad",
    "type": "git"
  },
  "keywords": [
    "markdown",
    "notes",
    "notepad",
    "sidebar",
    "editor"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "mdpad.notesView",
          "name": "mdpad"
        }
      ]
    },
    "commands": [
      {
        "command": "mdpad.openPanel",
        "title": "Mdpad: Open as Panel",
        "icon": "$(notebook)"
      },
      {
        "command": "mdpad.newPage",
        "title": "Mdpad: New Page"
      },
      {
        "command": "mdpad.deletePage",
        "title": "Mdpad: Delete Current Page"
      },
      {
        "command": "mdpad.toggleBold",
        "title": "Mdpad: Toggle Bold"
      },
      {
        "command": "mdpad.toggleItalic",
        "title": "Mdpad: Toggle Italic"
      },
      {
        "command": "mdpad.toggleStrikethrough",
        "title": "Mdpad: Toggle Strikethrough"
      }
    ],
    "keybindings": [
      {
        "command": "mdpad.toggleBold",
        "key": "ctrl+b",
        "when": "mdpad.focused && !isMac"
      },
      {
        "command": "mdpad.toggleItalic",
        "key": "ctrl+i",
        "when": "mdpad.focused && !isMac"
      },
      {
        "command": "mdpad.toggleStrikethrough",
        "key": "ctrl+shift+x",
        "when": "mdpad.focused && !isMac"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "webpack --mode production",
    "webpack": "webpack --mode development",
    "webpack-dev": "webpack --mode development --watch",
    "compile": "tsc -p ./",
    "lint": "eslint src --ext ts",
    "watch": "webpack --mode development --watch",
    "pretest": "pnpm compile && pnpm lint",
    "test": "node ./out/test/runTest.js",
    "deploy": "vsce publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^4.1.1",
    "@typescript-eslint/parser": "^4.1.1",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^3.0.0",
    "css-loader": "^7.0.0",
    "eslint": "^7.9.0",
    "eslint-config-airbnb-base": "^14.2.0",
    "eslint-config-prettier": "^6.15.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-prettier": "^3.1.4",
    "glob": "^10.3.0",
    "mocha": "^10.2.0",
    "prettier": "^2.1.2",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.7.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.35.0",
    "@lezer/markdown": "^1.3.0",
    "codemirror": "^6.0.0"
  }
}
