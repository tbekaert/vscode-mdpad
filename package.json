{
  "name": "mdpad",
  "displayName": "mdpad",
  "description": "A lightweight markdown notepad inside VS Code",
  "version": "0.3.1",
  "publisher": "tbekaert",
  "packageManager": "pnpm@10.29.2",
  "license": "GPL-3.0-or-later",
  "icon": "images/icon.png",
  "repository": {
    "url": "https://github.com/tbekaert/vscode-mdpad",
    "type": "git"
  },
  "homepage": "https://github.com/tbekaert/vscode-mdpad#readme",
  "bugs": {
    "url": "https://github.com/tbekaert/vscode-mdpad/issues"
  },
  "keywords": [
    "markdown",
    "notes",
    "notepad",
    "sidebar",
    "editor"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "categories": [
    "Notebooks"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "mdpad.notesView",
          "name": "mdpad"
        }
      ]
    },
    "commands": [
      {
        "command": "mdpad.openPanel",
        "title": "Open as Panel",
        "category": "mdpad",
        "icon": "$(notebook)"
      },
      {
        "command": "mdpad.previousPage",
        "title": "Previous Page",
        "category": "mdpad",
        "icon": "$(arrow-left)"
      },
      {
        "command": "mdpad.nextPage",
        "title": "Next Page",
        "category": "mdpad",
        "icon": "$(arrow-right)"
      },
      {
        "command": "mdpad.selectPage",
        "title": "Select Page",
        "category": "mdpad",
        "icon": "$(list-flat)"
      },
      {
        "command": "mdpad.newPage",
        "title": "New Page",
        "category": "mdpad",
        "icon": "$(add)"
      },
      {
        "command": "mdpad.deletePage",
        "title": "Delete Current Page",
        "category": "mdpad",
        "icon": "$(trash)"
      },
      {
        "command": "mdpad.switchToGlobal",
        "title": "Switch to Global Notes",
        "category": "mdpad",
        "icon": "$(globe)"
      },
      {
        "command": "mdpad.switchToWorkspace",
        "title": "Switch to Workspace Notes",
        "category": "mdpad",
        "icon": "$(root-folder)"
      },
      {
        "command": "mdpad.searchPages",
        "title": "Search Across Pages",
        "category": "mdpad",
        "icon": "$(search)"
      },
      {
        "command": "mdpad.find",
        "title": "Find in Note",
        "category": "mdpad",
        "icon": "$(search)"
      },
      {
        "command": "mdpad.exportPage",
        "title": "Export Current Page",
        "category": "mdpad",
        "icon": "$(export)"
      },
      {
        "command": "mdpad.openSettings",
        "title": "Open Settings",
        "category": "mdpad",
        "icon": "$(gear)"
      },
      {
        "command": "mdpad.toggleBold",
        "title": "Toggle Bold",
        "category": "mdpad"
      },
      {
        "command": "mdpad.toggleItalic",
        "title": "Toggle Italic",
        "category": "mdpad"
      },
      {
        "command": "mdpad.toggleStrikethrough",
        "title": "Toggle Strikethrough",
        "category": "mdpad"
      },
      {
        "command": "mdpad.toggleCode",
        "title": "Toggle Inline Code",
        "category": "mdpad"
      },
      {
        "command": "mdpad.toggleHighlight",
        "title": "Toggle Highlight",
        "category": "mdpad"
      },
      {
        "command": "mdpad.toggleHeading",
        "title": "Cycle Heading Level",
        "category": "mdpad"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mdpad.previousPage",
          "group": "navigation@0",
          "when": "view == mdpad.notesView"
        },
        {
          "command": "mdpad.nextPage",
          "group": "navigation@1",
          "when": "view == mdpad.notesView"
        },
        {
          "command": "mdpad.selectPage",
          "group": "navigation@2",
          "when": "view == mdpad.notesView"
        },
        {
          "command": "mdpad.newPage",
          "group": "navigation@4",
          "when": "view == mdpad.notesView"
        },
        {
          "command": "mdpad.switchToGlobal",
          "group": "navigation@5",
          "when": "view == mdpad.notesView && mdpad.scope == workspace"
        },
        {
          "command": "mdpad.switchToWorkspace",
          "group": "navigation@5",
          "when": "view == mdpad.notesView && mdpad.scope == global"
        },
        {
          "command": "mdpad.searchPages",
          "group": "2_mdpad@0",
          "when": "view == mdpad.notesView"
        },
        {
          "command": "mdpad.find",
          "group": "2_mdpad@1",
          "when": "view == mdpad.notesView"
        },
        {
          "command": "mdpad.openPanel",
          "group": "2_mdpad@1",
          "when": "view == mdpad.notesView"
        },
        {
          "command": "mdpad.exportPage",
          "group": "2_mdpad@2",
          "when": "view == mdpad.notesView"
        },
        {
          "command": "mdpad.deletePage",
          "group": "3_mdpad@1",
          "when": "view == mdpad.notesView"
        },
        {
          "command": "mdpad.openSettings",
          "group": "4_mdpad@1",
          "when": "view == mdpad.notesView"
        }
      ]
    },
    "keybindings": [
      {
        "command": "mdpad.toggleBold",
        "key": "ctrl+b",
        "mac": "cmd+b",
        "when": "mdpad.focused"
      },
      {
        "command": "mdpad.toggleItalic",
        "key": "ctrl+i",
        "mac": "cmd+i",
        "when": "mdpad.focused"
      },
      {
        "command": "mdpad.toggleStrikethrough",
        "key": "ctrl+d",
        "mac": "cmd+d",
        "when": "mdpad.focused"
      },
      {
        "command": "mdpad.toggleCode",
        "key": "ctrl+k",
        "mac": "cmd+k",
        "when": "mdpad.focused"
      },
      {
        "command": "mdpad.toggleHighlight",
        "key": "ctrl+e",
        "mac": "cmd+e",
        "when": "mdpad.focused"
      },
      {
        "command": "mdpad.toggleHeading",
        "key": "ctrl+h",
        "mac": "cmd+h",
        "when": "mdpad.focused"
      },
      {
        "command": "mdpad.find",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "mdpad.focused"
      },
      {
        "command": "mdpad.searchPages",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "mdpad.focused"
      },
      {
        "command": "mdpad.previousPage",
        "key": "ctrl+shift+[",
        "mac": "cmd+shift+[",
        "when": "mdpad.focused"
      },
      {
        "command": "mdpad.nextPage",
        "key": "ctrl+shift+]",
        "mac": "cmd+shift+]",
        "when": "mdpad.focused"
      },
      {
        "command": "mdpad.newPage",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "mdpad.focused"
      },
      {
        "command": "mdpad.deletePage",
        "key": "ctrl+w",
        "mac": "cmd+w",
        "when": "mdpad.focused"
      }
    ],
    "configuration": {
      "title": "mdpad",
      "properties": {
        "mdpad.fontFamily": {
          "type": "string",
          "default": "inherit",
          "description": "Font family for the editor. \"inherit\" uses the VS Code theme font."
        },
        "mdpad.lineHeight": {
          "type": "number",
          "default": 1.6,
          "description": "Line height in the editor."
        },
        "mdpad.lineWrapping": {
          "type": "boolean",
          "default": true,
          "description": "Wrap long lines."
        },
        "mdpad.folding": {
          "type": "boolean",
          "default": false,
          "description": "Enable section folding for H2, H3 headings and frontmatter."
        },
        "mdpad.listIndentSize": {
          "type": "number",
          "default": 2,
          "description": "Number of spaces per list indent level."
        },
        "mdpad.lineNumbers": {
          "type": "boolean",
          "default": false,
          "description": "Show line numbers in the gutter."
        },
        "mdpad.syncGlobalNotes": {
          "type": "boolean",
          "default": false,
          "description": "Sync global notes across devices via VS Code Settings Sync. Opt-in: synced data cannot be removed from the remote once synced."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "webpack --mode production",
    "webpack": "webpack --mode development",
    "webpack-dev": "webpack --mode development --watch",
    "compile": "tsc -p ./",
    "lint": "biome check src/",
    "format": "biome check --write src/",
    "watch": "webpack --mode development --watch",
    "pretest": "pnpm compile",
    "test": "pnpm test:unit && pnpm test:e2e && pnpm test:integration",
    "test:unit": "mocha out/test/unit/**/*.test.js",
    "test:integration": "vscode-test",
    "pretest:e2e": "pnpm webpack",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "deploy": "vsce publish",
    "changeset": "changeset",
    "publish:extension": "pnpm vscode:prepublish && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@bekaert-dev/biome-config": "^0.1.1",
    "@biomejs/biome": "^2.4.11",
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.59.1",
    "@types/jsdom": "^28.0.1",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "css-loader": "^7.0.0",
    "http-server": "^14.1.1",
    "jsdom": "^29.0.2",
    "mocha": "^10.2.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.7.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-less": "^6.0.2",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sass": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.10.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.35.0",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.3.0",
    "codemirror": "^6.0.0"
  }
}
