{
	"name": "mdpad",
	"displayName": "mdpad",
	"description": "Take notes in your sidebar using markdown",
	"version": "0.0.1",
	"publisher": "tbekaert",
	"license": "GPL-3.0-or-later",
	"icon": "images/icon.png",
	"repository": {
		"url": "https://github.com/tbekaert/vscode-mdpad",
		"type": "git"
	},
	"keywords": [
		"markdown",
		"notes",
		"view",
		"sidebar",
		"github",
		"flavored",
		"todo",
		"checklist"
	],
	"engines": {
		"vscode": "^1.75.0"
	},
	"extensionKind": [
		"ui",
		"workspace"
	],
	"categories": [
		"Other"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"views": {
			"explorer": [
				{
					"type": "webview",
					"id": "mdpad.webview",
					"name": "mdpad"
				}
			]
		},
		"commands": [
			{
				"command": "mdpad.resetData",
				"category": "mdpad",
				"title": "Reset data"
			},
			{
				"command": "mdpad.previousPage",
				"category": "mdpad",
				"title": "Previous page",
				"icon": "$(arrow-left)"
			},
			{
				"command": "mdpad.nextPage",
				"category": "mdpad",
				"title": "Next page",
				"icon": "$(arrow-right)"
			},
			{
				"command": "mdpad.togglePreview",
				"category": "mdpad",
				"title": "Toggle preview",
				"icon": "$(open-preview)"
			},
			{
				"command": "mdpad.exportPage",
				"category": "mdpad",
				"title": "Export page",
				"icon": "$(symbol-reference)"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "mdpad.previousPage",
					"group": "navigation@0",
					"when": "view == mdpad.webview"
				},
				{
					"command": "mdpad.nextPage",
					"group": "navigation@1",
					"when": "view == mdpad.webview"
				},
				{
					"command": "mdpad.togglePreview",
					"group": "navigation@2",
					"when": "view == mdpad.webview"
				},
				{
					"command": "mdpad.exportPage",
					"group": "navigation@3",
					"when": "view == mdpad.webview"
				}
			]
		},
		"configuration": [
			{
				"title": "mdpad",
				"properties": {
					"mdpad.leftMargin": {
						"type": "boolean",
						"default": false,
						"description": "Whether or not a left margin should be added to the main view. To align it with other elements"
					}
				}
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "webpack --mode production",
		"webpack": "webpack --mode development",
		"webpack-dev": "webpack --mode development --watch",
		"test-compile": "tsc -p ./",
		"compile": "tsc -p ./",
		"lint": "eslint src --ext ts",
		"watch": "webpack --mode development --watch",
		"pretest": "pnpm compile && pnpm lint",
		"test": "node ./out/test/runTest.js",
		"deploy": "vsce publish"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.0",
		"@types/node": "^20.0.0",
		"@types/vscode": "^1.75.0",
		"@typescript-eslint/eslint-plugin": "^4.1.1",
		"@typescript-eslint/parser": "^4.1.1",
		"@vscode/test-electron": "^2.3.0",
		"@vscode/vsce": "^3.0.0",
		"eslint": "^7.9.0",
		"eslint-config-airbnb-base": "^14.2.0",
		"eslint-config-prettier": "^6.15.0",
		"eslint-plugin-import": "^2.22.1",
		"eslint-plugin-prettier": "^3.1.4",
		"glob": "^10.3.0",
		"mocha": "^10.2.0",
		"prettier": "^2.1.2",
		"ts-loader": "^9.5.0",
		"typescript": "^5.7.0",
		"webpack": "^5.90.0",
		"webpack-cli": "^5.1.0"
	},
	"dependencies": {
		"dompurify": "^2.2.0",
		"lodash": "^4.17.20",
		"marked": "^1.2.2"
	}
}
