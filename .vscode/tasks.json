{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "shell",
			"command": "pnpm webpack",
			"problemMatcher": [],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "watch",
			"type": "shell",
			"command": "pnpm webpack-dev",
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^ERROR in (.+)$",
					"file": 1
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^asset",
					"endsPattern": "^webpack .+ compiled"
				}
			},
			"group": "build"
		}
	]
}
